BOT_TOKEN=123456:telegram-bot-token
DOWNLOAD_ROOT=./downloads
DB_PATH=./data/app.db

TDL_BIN=tdl
YT_DLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg

TDL_CMD=tdl dl -u {url} -d {output_dir}

URL_DOWNLOADER_CMD=yt-dlp -o {output_template} {url}

# 权限控制
ADMIN_USER_IDS=
ADMIN_USERNAMES=
ALLOWED_USER_IDS=
ALLOWED_USERNAMES=

# Web 管理后台
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8090
# Telegram 预览按钮对外访问用的基地址，例如 https://download.example.com
WEB_PUBLIC_BASE_URL=
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=change-this-password
WEB_SECRET_KEY=change-this-secret-key
WEB_SESSION_HOURS=24

# 代理（会自动从 .env 载入到环境变量，Telegram / webhook / 其它 httpx 请求都会生效）
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=127.0.0.1,localhost
